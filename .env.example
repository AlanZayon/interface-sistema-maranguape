# URL da API (produção / target do proxy em DEV)
VITE_API_BASE_URL=http://localhost:3000

# Em DEV o front usa proxy Vite (/api → VITE_API_BASE_URL) para cookies
# funcionarem em master.localhost e *.localhost.

# Domínio base para subdomínios de tenant.
# Em local: deixe vazio e use *.localhost
# Em produção: VITE_BASE_DOMAIN=seudominio.com
VITE_BASE_DOMAIN=

# Subdomínio do console master (superadmin)
VITE_MASTER_SUBDOMAIN=master

# Fallback DEV apenas (quando não há subdomínio)
VITE_TENANT_SLUG=

# Branding limits are enforced by the API (TENANT_* envs).
# The wizard loads them from GET /api/tenants/branding-policy — do not rely on VITE_* for security.
